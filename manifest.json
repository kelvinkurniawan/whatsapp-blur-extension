{
  "manifest_version": 3,
  "name": "WhatsApp Blur",
  "short_name": "WA Blur",
  "version": "1.1.0",
  "description": "Privacy-focused WhatsApp Web enhancement with glass morphism design and smart blur for sensitive information",
  "author": "Kelvin Kurniawan",

  "icons": {
    "128": "icon.png"
  },

  "action": {
    "default_title": "WhatsApp Blur - Toggle privacy blur (Cmd+Shift+0)",
    "default_popup": "popup.html"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "css": ["style.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "toggle-blur": {
      "suggested_key": {
        "default": "Ctrl+Shift+0",
        "mac": "Command+Shift+0"
      },
      "description": "Toggle privacy blur"
    },
    "toggle-screen-share": {
      "suggested_key": {
        "default": "Ctrl+Shift+9",
        "mac": "Command+Shift+9"
      },
      "description": "Toggle screen share mode (blur messages too)"
    }
  }
}
