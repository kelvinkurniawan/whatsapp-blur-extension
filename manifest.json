{
  "manifest_version": 3,
  "name": "WhatsApp Blur",
  "short_name": "WA Blur",
  "version": "1.0.0",
  "description": "Privacy-focused WhatsApp Web enhancement with glass morphism design and smart blur for sensitive information",
  "author": "Kelvin Kurniawan",

  "icons": {
    "128": "icon.png"
  },

  "action": {
    "default_title": "WhatsApp Blur - Toggle privacy blur (Cmd+Shift+0)"
  },

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "css": ["style.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
